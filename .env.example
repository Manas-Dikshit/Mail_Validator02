# Copy to .env and adjust as needed. All variables are optional (sane defaults exist).

EMAILVAL_LOG_LEVEL=INFO
EMAILVAL_LOG_JSON=false

EMAILVAL_DNS_TIMEOUT_SECONDS=3.0
EMAILVAL_DNS_LIFETIME_SECONDS=5.0
EMAILVAL_DNS_MAX_RETRIES=2
EMAILVAL_DNS_CACHE_TTL_SECONDS=3600
EMAILVAL_DNS_THREAD_POOL_WORKERS=32

EMAILVAL_CSV_CHUNK_SIZE=5000
EMAILVAL_MAX_UPLOAD_ROWS=500000
EMAILVAL_MAX_UPLOAD_SIZE_MB=100
